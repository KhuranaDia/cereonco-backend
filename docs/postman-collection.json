{
  "info": {
    "name": "CereOnco Community API",
    "description": "Phase 1 (Auth/Users) + Phase 2 (Posts/Likes/Bookmarks) + Phase 3 (Roles Extension)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "0.3.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://<your-domain>/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "token_md",
      "value": "",
      "type": "string"
    },
    {
      "key": "post_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/healthz",
            "description": "Returns { status: 'ok' } when the server is running."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (patient)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ananya Sharma\",\n  \"email\": \"ananya@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"patient\"\n}"
            },
            "description": "Register a new patient. Auto-saves token to collection variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json().data;",
                  "pm.test('Has token', () => pm.expect(d.token).to.be.a('string'));",
                  "pm.test('Role is patient', () => pm.expect(d.user.role).to.eql('patient'));",
                  "pm.test('verificationStatus is none', () => pm.expect(d.user.verificationStatus).to.eql('none'));",
                  "pm.test('onboardingCompleted is false', () => pm.expect(d.user.onboardingCompleted).to.eql(false));",
                  "pm.collectionVariables.set('token', d.token);",
                  "pm.collectionVariables.set('user_id', d.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register (medical_professional)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Priya Nair\",\n  \"email\": \"priya@cereoncomed.com\",\n  \"password\": \"password123\",\n  \"role\": \"medical_professional\"\n}"
            },
            "description": "Register a medical professional. Auto-saves token to token_md variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json().data;",
                  "pm.test('Role is medical_professional', () => pm.expect(d.user.role).to.eql('medical_professional'));",
                  "pm.test('verificationStatus is none', () => pm.expect(d.user.verificationStatus).to.eql('none'));",
                  "pm.collectionVariables.set('token_md', d.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register (caregiver)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rohan Mehta\",\n  \"email\": \"rohan@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"caregiver\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Role is caregiver', () => pm.expect(pm.response.json().data.user.role).to.eql('caregiver'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — 409 duplicate email",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dup\",\n  \"email\": \"ananya@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"patient\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('success false', () => pm.expect(pm.response.json().success).to.eql(false));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ananya@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.test('Has token', () => pm.expect(d.token).to.be.a('string'));",
                  "pm.collectionVariables.set('token', d.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — 401 wrong password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ananya@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Stateless logout. Accepts optional Bearer token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.eql(true));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const u = pm.response.json().data;",
                  "pm.test('Has role', () => pm.expect(u.role).to.be.a('string'));",
                  "pm.test('Has verificationStatus', () => pm.expect(u.verificationStatus).to.be.a('string'));",
                  "pm.test('Has onboardingCompleted', () => pm.expect(u).to.have.property('onboardingCompleted'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Me — 401 no token",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Me — patient onboarding",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Stage 3 breast cancer survivor, one day at a time.\",\n  \"cancerType\": \"Breast Cancer\",\n  \"treatmentStage\": \"remission\",\n  \"interests\": [\"support_groups\", \"nutrition\", \"mindfulness\"],\n  \"profilePhotoUrl\": \"https://cdn.example.com/photos/ananya.jpg\",\n  \"location\": \"Mumbai\",\n  \"onboardingCompleted\": true\n}"
            },
            "description": "Complete onboarding for a patient — cancer type, treatment stage, interests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const u = pm.response.json().data;",
                  "pm.test('cancerType set', () => pm.expect(u.cancerType).to.eql('Breast Cancer'));",
                  "pm.test('treatmentStage set', () => pm.expect(u.treatmentStage).to.eql('remission'));",
                  "pm.test('interests is array', () => pm.expect(u.interests).to.be.an('array'));",
                  "pm.test('onboardingCompleted true', () => pm.expect(u.onboardingCompleted).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Me — MD onboarding (auto-pending)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_md}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specialty\": \"Oncology\",\n  \"hospitalAffiliation\": \"AIIMS Delhi\",\n  \"medicalLicenseNumber\": \"MH-2024-ON-7831\",\n  \"profilePhotoUrl\": \"https://cdn.example.com/photos/priya.jpg\",\n  \"location\": \"New Delhi\",\n  \"onboardingCompleted\": true\n}"
            },
            "description": "Complete MD onboarding. Submitting medicalLicenseNumber when verificationStatus=none auto-sets it to 'pending'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const u = pm.response.json().data;",
                  "pm.test('specialty set', () => pm.expect(u.specialty).to.eql('Oncology'));",
                  "pm.test('hospitalAffiliation set', () => pm.expect(u.hospitalAffiliation).to.eql('AIIMS Delhi'));",
                  "pm.test('verificationStatus is pending', () => pm.expect(u.verificationStatus).to.eql('pending'));",
                  "pm.test('onboardingCompleted true', () => pm.expect(u.onboardingCompleted).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Me — partial (name + bio)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ananya S.\",\n  \"bio\": \"Survivor. Advocate. Fighter.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('name updated', () => pm.expect(pm.response.json().data.name).to.eql('Ananya S.'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/{{user_id}}",
            "description": "Public profile — no auth required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const u = pm.response.json().data;",
                  "pm.test('Has id', () => pm.expect(u.id).to.be.a('number'));",
                  "pm.test('Has verificationStatus', () => pm.expect(u.verificationStatus).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User by ID — 404",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/99999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/posts",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello CereOnco community! Glad to be here.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json().data;",
                  "pm.test('Has content', () => pm.expect(d.content).to.be.a('string'));",
                  "pm.collectionVariables.set('post_id', d.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Feed (authenticated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/posts?limit=10&offset=0",
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const feed = pm.response.json().data;",
                  "pm.test('Is array', () => pm.expect(feed).to.be.an('array'));",
                  "if (feed.length > 0) {",
                  "  pm.test('Has isLiked', () => pm.expect(feed[0]).to.have.property('isLiked'));",
                  "  pm.test('Has isBookmarked', () => pm.expect(feed[0]).to.have.property('isBookmarked'));",
                  "  pm.test('Has author', () => pm.expect(feed[0].author).to.have.property('role'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Feed (unauthenticated)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts/{{post_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has likeCount', () => pm.expect(pm.response.json().data).to.have.property('likeCount'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/posts/{{post_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Updated: Hello CereOnco community!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Like Post",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/posts/{{post_id}}/like",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('liked true', () => pm.expect(pm.response.json().data.liked).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Like Post (idempotent)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/posts/{{post_id}}/like",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Double-liking is silently ignored. likeCount should not increase."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Bookmark Post",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/posts/{{post_id}}/bookmark",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('bookmarked true', () => pm.expect(pm.response.json().data.bookmarked).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Unlike Post",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/posts/{{post_id}}/like",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('liked false', () => pm.expect(pm.response.json().data.liked).to.eql(false));"
                ]
              }
            }
          ]
        },
        {
          "name": "Unbookmark Post",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/posts/{{post_id}}/bookmark",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('bookmarked false', () => pm.expect(pm.response.json().data.bookmarked).to.eql(false));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Post — 403 not owner",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/posts/{{post_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_md}}" }],
            "description": "Attempt to delete a post owned by another user. Should return 403."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/posts/{{post_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Post — 404 after delete",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/posts/{{post_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
